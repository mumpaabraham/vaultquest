rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /packages/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /notifications/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    match /apk/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
