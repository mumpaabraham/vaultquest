rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Admin: full access to everything ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ── App settings (read-only for signed-in users) ───────────────────────────
    match /settings/{document} {
      allow read: if isSignedIn();
    }

    // ── Investment packages (read-only for signed-in users) ────────────────────
    match /packages/{packageId} {
      allow read: if isSignedIn();
    }

    // ── Live Spins (real-time spin activity; admin-read only) ────────────────────
    match /liveSpins/{userId} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn()
        && isOwner(userId)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // ── Deposits (top-level; users create their own) ───────────────────────────
    match /deposits/{depositId} {
      allow read: if isSignedIn()
        && (isOwner(resource.data.uid) || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll([
             'uid', 'userDisplayName', 'amount', 'mobileProvider',
             'mobileNumber', 'payerName', 'status'
           ])
        && request.resource.data.status == 'pending'
        && request.resource.data.amount > 0;

      allow update, delete: if false;
    }

    // ── Admins collection ──────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read: if isAdmin();
    }

    // ── Broadcast notifications (admin write, signed-in read) ─────────────────
    match /notifications/{notifId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── App versions (admin write, public read) ────────────────────────────────
    match /appVersions/{versionId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Download records (users create own, admin reads) ──────────────────────
    match /downloads/{downloadId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'versionId', 'versionName', 'platform', 'downloadedAt']);
      allow read: if isAdmin();
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:  if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn()
        && isOwner(userId)
        && request.resource.data.keys().hasAll([
             'displayName', 'email', 'level', 'xp', 'walletBalance',
             'referralCode', 'freeSpinsAvailable'
           ])
        && request.resource.data.level        == 1
        && request.resource.data.xp           == 0
        && request.resource.data.walletBalance == 0;

      allow update: if isSignedIn()
        && isOwner(userId)
        && request.resource.data.email      == resource.data.email
        && request.resource.data.referredBy == resource.data.referredBy;

      allow delete: if false;

      // ── FCM token registration (user can only append own token) ─────────────
      allow update: if isSignedIn()
        && isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['expoPushTokens']);

      // ── Vaults ─────────────────────────────────────────────────────────────
      match /vaults/{vaultId} {
        allow read: if isSignedIn() && isOwner(userId);

        allow create: if isSignedIn()
          && isOwner(userId)
          && request.resource.data.keys().hasAll([
               'tierId', 'tierName', 'invested', 'dailyEarnings',
               'durationDays', 'status', 'startDate', 'endDate',
               'totalEarned', 'lastPayout'
             ])
          && request.resource.data.status      == 'active'
          && request.resource.data.totalEarned == 0
          && request.resource.data.invested     >  0;

        allow update: if isSignedIn()
          && isOwner(userId)
          && request.resource.data.tierId     == resource.data.tierId
          && request.resource.data.invested   == resource.data.invested
          && request.resource.data.startDate  == resource.data.startDate
          && request.resource.data.endDate    == resource.data.endDate;

        allow delete: if false;
      }

      // ── Spin History ────────────────────────────────────────────────────────
      match /spinHistory/{spinId} {
        allow read: if isSignedIn() && isOwner(userId);

        allow create: if isSignedIn()
          && isOwner(userId)
          && request.resource.data.keys().hasAll(['label', 'type', 'value', 'timestamp'])
          && request.resource.data.type in ['cash', 'xp', 'boost', 'spin_bonus'];

        allow update, delete: if false;
      }

      // ── Transactions ────────────────────────────────────────────────────────
      match /transactions/{txId} {
        allow read: if isSignedIn() && isOwner(userId);

        allow create: if isSignedIn()
          && isOwner(userId)
          && request.resource.data.keys().hasAll(['type', 'amount', 'description', 'timestamp'])
          && request.resource.data.type in ['deposit', 'withdrawal', 'earning', 'referral'];

        allow update, delete: if false;
      }

      // ── Mission Progress ────────────────────────────────────────────────────
      match /missionProgress/{missionId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow write: if false;
      }

      // ── Withdrawals ─────────────────────────────────────────────────────────
      match /withdrawals/{wId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow write: if false;
      }
    }
  }
}
